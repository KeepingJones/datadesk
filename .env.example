# DataDesk — Environment Template
# Copy this file to .env and fill in your values.
# .env is in .gitignore and is NEVER committed. This template is safe to commit.

# ─── T212 (UK/EU equities via ISA) ───────────────────────────────────────────
T212_MODE=demo                        # "demo" (safe) or "live" (real money — handle with care)
T212_DEMO_API_KEY=your_t212_demo_key_here
T212_LIVE_API_KEY=your_t212_live_key_here

# ─── Alpaca (US equities, paper trading) ─────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ─── DataDesk control flags ───────────────────────────────────────────────────
# DATADESK_ARM_BROKER: "0" = shadow mode (signals recorded, no execution)
#                      "1" = armed (broker calls execute — requires keys above)
# Default is "0". Never set to "1" without reviewing risk limits first.
DATADESK_ARM_BROKER=0

# ─── Database paths ───────────────────────────────────────────────────────────
DATADESK_DB_PATH=datadesk/data/datadesk.db
ALTDATA_DB_PATH=datadesk/data/altdata.db
DATA_DIR=datadesk/data

# ─── Data providers ───────────────────────────────────────────────────────────
TIINGO_API_KEY=your_tiingo_key_here       # Optional — used for point-in-time universe
FRED_API_KEY=your_fred_key_here           # Free at fred.stlouisfed.org

# ─── Fund settings ────────────────────────────────────────────────────────────
FUND_BASE_CURRENCY=GBP

# ─── AI / LLM (optional — powers thesis generator and news analysis) ──────────
ANALYST_MODEL=gemini-2.5-pro              # or any model supported by your setup
OLLAMA_URL=http://localhost:11434         # if using local models via Ollama
